; Engine configuration file.
; This is "This Is Not A Weapon" — a top-down graybox for the combine mechanic.
; Generated by hand; Godot will rewrite/expand this on first open.

config_version=5

[application]

config/name="This Is Not A Weapon"
config/description="Graybox: combine random junk into weapons/tools. Prove the verb is fun."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="forward_plus"
